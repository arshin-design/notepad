// Prisma 스키마 - Turso(libsql/SQLite) 사용 (인증 없는 단일 사용자 메모장)
generator client {
  provider        = "prisma-client-js"
  // libsql 드라이버 어댑터로 Turso에 연결하기 위해 필요
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // 런타임 연결은 libsql 어댑터(TURSO_URL/TURSO_TOKEN)를 사용한다.
  // 이 url은 Prisma CLI(generate/migrate diff)에서만 쓰이는 로컬 더미 값이다.
  url      = env("DATABASE_URL")
}

// 노트북 (폴더)
model Notebook {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  notes Note[]
}

// 노트
model Note {
  id        String   @id @default(cuid())
  title     String   @default("제목 없음")
  content   String   @default("") // 리치 텍스트(HTML)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notebookId String?
  notebook   Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)

  tags Tag[]

  @@index([notebookId])
}

// 태그
model Tag {
  id   String @id @default(cuid())
  name String @unique

  notes Note[]
}
