// Prisma 스키마 - PostgreSQL 사용 (인증 없는 단일 사용자 메모장)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 노트북 (폴더)
model Notebook {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  notes Note[]
}

// 노트
model Note {
  id        String   @id @default(cuid())
  title     String   @default("제목 없음")
  content   String   @default("") // 리치 텍스트(HTML)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notebookId String?
  notebook   Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)

  tags Tag[]

  @@index([notebookId])
}

// 태그
model Tag {
  id   String @id @default(cuid())
  name String @unique

  notes Note[]
}
